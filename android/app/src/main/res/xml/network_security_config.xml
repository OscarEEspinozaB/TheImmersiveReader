<?xml version="1.0" encoding="utf-8"?>
<!--
  The app talks to the home-server (dictionary KB + AI explanations + sync) over
  plain HTTP on the LAN, e.g. http://192.168.100.6:4321. Android 9+ blocks
  cleartext traffic by default, so we opt back in here. This is a trusted-LAN
  personal app; keep it HTTP-on-LAN only. If the server ever moves behind HTTPS,
  tighten this back down.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
