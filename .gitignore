# Dependencies
node_modules/

# Build output
dist/

# Logs
*.log
npm-debug.log*

# Editor / OS
.DS_Store
.vscode/
.idea/

# Env
.env
.env.*

# User books / copyrighted material — never publish these
*.pdf
*.epub

# Dictionary KB service: heavy source dumps + generated SQLite database
data/
*.sqlite
*.sqlite-shm
*.sqlite-wal

# Android (Capacitor): keep the project source, drop build artifacts + local config.
# The web assets under android/app/src/main/assets/public are regenerated by
# `npm run cap:sync`, so they don't belong in git either.
android/app/src/main/assets/public/
android/.gradle/
android/build/
android/app/build/
android/local.properties
android/capacitor-cordova-android-plugins/
*.apk
*.aab

# image files Gemini uses for its own purposes, but which are not part of the source code.
Gemini*

# Ignore GitHub Files for GitHub Actions, which are generated by the GitHub Actions workflow and not part of the source code.
.gitignore